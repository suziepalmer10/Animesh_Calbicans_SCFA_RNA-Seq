pca_plot <- function(dds_table, title = NULL, palette = NULL, point_size = 4) {
  vsd <- vst(dds_table, blind = FALSE)
  pca_df <- plotPCA(vsd, intgroup = "Group", returnData = TRUE)
  percentVar <- round(100 * attr(pca_df, "percentVar"))
  
  # Make a palette that matches the groups present in this dds_table
  groups_present <- levels(droplevels(colData(dds_table)$Group))
  if (is.null(palette)) {
    palette <- palette_12
  }
  pal_use <- setNames(palette[seq_along(groups_present)], groups_present)
  
  ggplot(pca_df, aes(PC1, PC2, color = Group)) +
    geom_point(size = point_size) +
    scale_color_manual(values = pal_use, drop = TRUE) +
    xlab(paste0("PC1: ", percentVar[1], "% variance")) +
    ylab(paste0("PC2: ", percentVar[2], "% variance")) +
    labs(title = title) +
    theme_bw() +
    theme(
      text = element_text(size = 14),
      legend.title = element_text(size = 12),
      legend.text  = element_text(size = 10)
    )
}

