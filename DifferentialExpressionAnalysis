make_upset_from_compare_results <- function(
    results_obj,
    pdf_file,
    pattern_col = "Pattern",
    count_col   = "Count",
    sep         = "&",
    width       = 9,
    height      = 6,
    ...
) {
  stopifnot(!is.null(results_obj$summary_patterns))
  
  df <- results_obj$summary_patterns %>%
    tibble::as_tibble() %>%
    dplyr::mutate(
      !!pattern_col := as.character(.data[[pattern_col]]),
      !!count_col   := as.integer(.data[[count_col]])
    ) %>%
    dplyr::group_by(.data[[pattern_col]]) %>%
    dplyr::summarise(!!count_col := sum(.data[[count_col]]), .groups = "drop")
  
  sets <- df %>%
    tidyr::separate_rows(!!rlang::sym(pattern_col), sep = sep) %>%
    dplyr::distinct(.data[[pattern_col]]) %>%
    dplyr::pull(.data[[pattern_col]])
  
  if (length(sets) == 0) stop("No sets found after splitting Pattern.")
  if (nrow(df) == 0) stop("summary_patterns has 0 rows after processing.")
  
  upset_df <- df %>%
    dplyr::mutate(
      row_id = dplyr::row_number(),
      tmp = .data[[pattern_col]]
    ) %>%
    tidyr::separate_rows(tmp, sep = sep) %>%
    dplyr::mutate(value = 1L) %>%
    tidyr::pivot_wider(
      id_cols     = c(row_id, !!rlang::sym(count_col)),
      names_from  = tmp,
      values_from = value,
      values_fill = 0L,
      values_fn   = max
    )
  
  expanded_mat <- upset_df %>%
    tidyr::uncount(weights = .data[[count_col]]) %>%
    dplyr::select(dplyr::all_of(sets)) %>%
    dplyr::mutate(dplyr::across(dplyr::everything(), as.integer)) %>%
    as.data.frame()
  
  if (nrow(expanded_mat) == 0) {
    stop("expanded_mat has 0 rows after uncount(). Counts may all be 0 or missing.")
  }
  
  grDevices::pdf(pdf_file, width = width, height = height, onefile = TRUE)
  on.exit(grDevices::dev.off(), add = TRUE)
  
  p <- UpSetR::upset(
    expanded_mat,
    sets = sets,
    keep.order = TRUE,
    order.by = "freq",
    ...
  )
  
  # IMPORTANT: forces rendering to the PDF device in non-interactive contexts
  print(p)
  
  invisible(list(df = df, sets = sets, expanded_mat = expanded_mat, pdf_file = pdf_file))
}

