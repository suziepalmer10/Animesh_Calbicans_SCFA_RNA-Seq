compare_regulated_genes <- function(sig_list, direction = c("down", "up")) {
  direction <- match.arg(direction)
  
  # 1) filter each df to up/down genes
  regulated <- lapply(sig_list, function(df) {
    if (direction == "down") df[df$log2FoldChange < 0, , drop = FALSE]
    else df[df$log2FoldChange > 0, , drop = FALSE]
  })
  
  # 2) gene sets as character vectors (rownames are assumed to be gene IDs)
  gene_sets <- lapply(regulated, rownames)
  groups <- names(gene_sets)
  
  # 3) all genes seen in any group
  genes_union <- sort(unique(unlist(gene_sets, use.names = FALSE)))
  
  # 4) membership matrix: rows=genes, cols=groups, TRUE if gene in that group
  mem <- sapply(gene_sets, function(gs) genes_union %in% gs)
  rownames(mem) <- genes_union
  
  # 5) encode each gene's membership pattern (e.g., "YPD_vs_DMSO&LA_vs_DMSO")
  pattern_label <- apply(mem, 1, function(x) {
    present <- groups[which(x)]
    paste(present, collapse = "&")
  })
  
  # 6) genes split by exact pattern
  genes_by_pattern <- split(genes_union, pattern_label)
  
  # 7) convenience objects similar to your originals
  genes_all <- genes_by_pattern[[paste(groups, collapse = "&")]]
  if (is.null(genes_all)) genes_all <- character(0)
  
  genes_unique <- setNames(
    lapply(groups, function(g) {
      key <- g
      if (!is.null(genes_by_pattern[[key]])) genes_by_pattern[[key]] else character(0)
    }),
    paste0(groups, "_only")
  )
  
  # 8) "exactly k groups" overlaps (k=1..length(groups))
  k <- rowSums(mem)
  genes_exactly_k <- setNames(
    lapply(1:length(groups), function(kk) rownames(mem)[k == kk]),
    paste0("in_exactly_", 1:length(groups), "_groups")
  )
  
  # 9) summary table for every pattern
  summary_patterns <- data.frame(
    Pattern = names(genes_by_pattern),
    Count   = lengths(genes_by_pattern),
    stringsAsFactors = FALSE
  )
  summary_patterns <- summary_patterns[order(-summary_patterns$Count), , drop = FALSE]
  
  list(
    regulated        = regulated,
    gene_sets        = gene_sets,
    genes_all        = genes_all,
    genes_unique     = genes_unique,
    genes_exactly_k  = genes_exactly_k,
    genes_by_pattern = genes_by_pattern,
    membership       = mem,
    summary_patterns = summary_patterns
  )
}

