parse_goa_other_names <- function(goa_file,
                                  gene_regex = "CAALFM_[A-Z0-9]+") {
  
  goa <- read.delim(goa_file, comment.char = "!", header = FALSE)
  colnames(goa) <- c(
    "DB","ID","Symbol","Qual","GO_ID","Ref","Evid","With",
    "Aspect","Name","Syn","Type","Taxon","Date",
    "Assigned","Ext","Form"
  )
  
  goa %>%
    dplyr::mutate(
      gene = stringr::str_extract(Syn, gene_regex),
      syn_split = stringr::str_split(Syn, "\\|"),
      Other_Name = dplyr::case_when(
        lengths(syn_split) >= 3 ~ sapply(syn_split, `[`, 1),
        lengths(syn_split) == 2 ~ sapply(syn_split, `[`, 2),
        TRUE ~ NA_character_
      )
    ) %>%
    dplyr::filter(!is.na(gene)) %>%
    dplyr::select(gene, Other_Name) %>%
    dplyr::distinct()
}

