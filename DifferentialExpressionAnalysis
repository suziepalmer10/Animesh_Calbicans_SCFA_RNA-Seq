#add enrichment ratios
add_enrichment_ratios <- function(ego_obj) {
  if (is.null(ego_obj)) return(NULL)
  
  ego_df <- as.data.frame(ego_obj)
  if (nrow(ego_df) == 0) return(ego_df)
  
  # parse "a/b"
  num_ratio <- function(x) {
    a <- as.numeric(sub("/.*", "", x))
    b <- as.numeric(sub(".*/", "", x))
    a / b
  }
  
  ego_df$GeneRatio_num    <- num_ratio(ego_df$GeneRatio)
  ego_df$BgRatio_num      <- num_ratio(ego_df$BgRatio)
  ego_df$EnrichmentRatio  <- ego_df$GeneRatio_num / ego_df$BgRatio_num
  
  ego_df
}

enriched_gene <- function(genes, TERM2GENE) {
  
  genes <- intersect(unique(genes), universe_genes)
  
  # NEW: keep only genes present in TERM2GENE mapping
  genes <- intersect(genes, unique(TERM2GENE$gene))
  
  if (length(genes) < min_genes_enrich) return(NULL)
  
  enricher(
    gene          = genes,
    universe      = intersect(universe_genes, unique(TERM2GENE$gene)), # optional but recommended
    TERM2GENE     = TERM2GENE,
    TERM2NAME     = TERM2NAME,
    pvalueCutoff  = 0.1,
    pAdjustMethod = "BH",
    minGSSize     = 2,     # consider relaxing from default 10
    maxGSSize     = 500
  )
}

kegg_enrich <- function(genes) {
  genes <- intersect(unique(genes), universe_genes)
  if (length(genes) < min_genes_enrich) return(NULL)
  
  enrichKEGG(
    gene          = genes,
    universe      = universe_genes,
    organism      = "cal",
    pvalueCutoff  = 0.1,
    pAdjustMethod = "BH"
  )
}

################################################################################
# GO (BP + MF) + KEGG ENRICHMENT
################################################################################
run_enrichment_for_patterns <- function(results_list,
                                        direction,
                                        pattern,
                                        base_dir,
                                        mode = c("individual", "genes_all"),
                                        genes_all_name = "ALL3") {
  
  mode <- match.arg(mode)
  
  ## create output folder: base_dir/pattern/direction
  out_dir <- file.path(base_dir, pattern, direction)
  dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
  
  ## Build gene sets to analyze
  if (mode == "individual") {
    gene_sets_in_dir <- lapply(results_list$regulated, rownames)  # named list by contrast
  } else {
    # genes_all is a character vector in your compare_regulated_genes() output
    genes <- results_list$genes_all
    if (is.null(genes)) stop("results_list$genes_all is NULL. Did compare_regulated_genes() create it?")
    if (length(genes) == 0) stop("results_list$genes_all is empty (no shared genes across all conditions).")
    
    gene_sets_in_dir <- setNames(list(genes), genes_all_name)
  }
  
  ## Loop over gene sets and run enrichment
  for (nm in names(gene_sets_in_dir)) {
    
    genes <- gene_sets_in_dir[[nm]]
    
    ## ---- GO BIOLOGICAL PROCESS ----
    ego_bp <- enriched_gene(genes, TERM2GENE_BP)
    ego_bp_df <- add_enrichment_ratios(ego_bp)
    
    if (!is.null(ego_bp_df) && nrow(ego_bp_df) > 0) {
      write.csv(
        ego_bp_df,
        file.path(out_dir, paste0("GO_BP_", direction, "_", nm, ".csv")),
        row.names = FALSE
      )
    }
    
    ## ---- GO MOLECULAR FUNCTION ----
    ego_mf <- enriched_gene(genes, TERM2GENE_MF)
    ego_mf_df <- add_enrichment_ratios(ego_mf)
    
    if (!is.null(ego_mf_df) && nrow(ego_mf_df) > 0) {
      write.csv(
        ego_mf_df,
        file.path(out_dir, paste0("GO_MF_", direction, "_", nm, ".csv")),
        row.names = FALSE
      )
    }
    
    ## ---- KEGG ----
    kegg <- kegg_enrich(genes)
    kegg_df <- tryCatch(as.data.frame(kegg), error = function(e) NULL)
    
    if (!is.null(kegg_df) && nrow(kegg_df) > 0) {
      out_file <- file.path(out_dir, paste0("KEGG_", direction, "_", nm, ".csv"))
      write.csv(kegg_df, out_file, row.names = FALSE)
      message("KEGG hits found for ", nm, " (", nrow(kegg_df), " terms)")
    } else {
      message("No KEGG hits for ", nm)
    }
  }
  
  invisible(NULL)
}

