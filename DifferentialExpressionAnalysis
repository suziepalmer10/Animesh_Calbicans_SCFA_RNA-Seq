parse_goa_term2gene <- function(goa_file, aspect,
                                regex = "CAALFM_[A-Z0-9]+") {
  
  goa <- read.delim(goa_file, comment.char = "!", header = FALSE)
  colnames(goa) <- c(
    "DB","ID","Symbol","Qual","GO_ID","Ref","Evid","With",
    "Aspect","Name","Syn","Type","Taxon","Date",
    "Assigned","Ext","Form"
  )
  
  goa %>%
    dplyr::mutate(gene = stringr::str_extract(Syn, regex)) %>%
    dplyr::filter(!is.na(gene), Aspect == aspect) %>%
    dplyr::select(GO_ID, gene) %>%
    dplyr::distinct()
}

