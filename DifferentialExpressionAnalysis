make_volcano_df <- function(res_test, res_shr) {
  data.frame(
    gene = rownames(res_test),
    log2FC = res_shr$log2FoldChange,
    padj   = res_test$padj,
    stringsAsFactors = FALSE
  ) %>%
    filter(!is.na(padj), !is.na(log2FC))
}

plot_volcano <- function(df, alpha, lfc_cutoff, title) {
  
  df$significance <- "NS"
  df$significance[df$padj < alpha & df$log2FC >  lfc_cutoff] <- "Up"
  df$significance[df$padj < alpha & df$log2FC < -lfc_cutoff] <- "Down"
  
  ggplot(df, aes(log2FC, -log10(padj), color = significance)) +
    geom_point(alpha = 0.6, size = 1.5) +
    scale_color_manual(values = c(
      Down = "#2C7BB6",
      Up   = "#D7191C",
      NS   = "grey70"
    )) +
    geom_vline(xintercept = c(-lfc_cutoff, lfc_cutoff), linetype = "dashed") +
    geom_hline(yintercept = -log10(alpha), linetype = "dashed") +
    labs(
      title = title,
      x = "Log2 Fold Change",
      y = "-log10 adjusted p-value",
      color = "Regulation"
    ) +
    theme_bw() +
    theme(text = element_text(size = 13))
}

