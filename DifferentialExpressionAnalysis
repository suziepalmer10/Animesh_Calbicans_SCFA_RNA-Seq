export_regulated_results_to_excel <- function(results_obj, outfile, max_sheetname = 31) {
  
  sheets <- list()
  
  # Helper: make Excel-safe sheet names (<=31 chars; remove forbidden chars)
  sanitize_sheet_name <- function(x) {
    x <- gsub("[:\\\\/\\?\\*\\[\\]]", "_", x)   # forbidden in Excel
    x <- gsub("&", "_AND_", x, fixed = TRUE)    # optional: avoid ampersand
    if (nchar(x) > max_sheetname) x <- substr(x, 1, max_sheetname)
    x
  }
  
  # --- 1) per-comparison regulated tables (with gene + Other_Name) ---
  for (nm in names(results_obj$regulated)) {
    df <- results_obj$regulated[[nm]]
    if (!is.null(df) && nrow(df) > 0) {
      df_out <- as.data.frame(df)
      df_out$gene <- rownames(df_out)
      rownames(df_out) <- NULL
      
      sheet_nm <- paste0("regulated_", nm)
      sheet_nm <- sanitize_sheet_name(sheet_nm)
      
      sheets[[sheet_nm]] <- df_out %>%
        dplyr::left_join(gene_id_map, by = "gene") %>%
        dplyr::relocate(Other_Name, .after = gene)
    }
  }
  
  # --- 2) exact overlap patterns (the main thing you asked for) ---
  if (!is.null(results_obj$genes_by_pattern) && length(results_obj$genes_by_pattern) > 0) {
    
    for (pat in names(results_obj$genes_by_pattern)) {
      genes <- results_obj$genes_by_pattern[[pat]]
      if (length(genes) > 0) {
        sheet_nm <- paste0("pattern_", pat)
        sheet_nm <- sanitize_sheet_name(sheet_nm)
        
        # If truncation causes duplicates, append a unique suffix
        if (sheet_nm %in% names(sheets)) {
          suffix <- sprintf("_%02d", sum(startsWith(names(sheets), sheet_nm)) + 1)
          sheet_nm <- sanitize_sheet_name(paste0(sheet_nm, suffix))
        }
        
        sheets[[sheet_nm]] <- data.frame(gene = genes, stringsAsFactors = FALSE) %>%
          dplyr::left_join(gene_id_map, by = "gene") %>%
          dplyr::relocate(Other_Name, .after = gene)
      }
    }
  }
  
  # --- 3) optional: genes in exactly k groups (k=1..N) ---
  if (!is.null(results_obj$genes_exactly_k) && length(results_obj$genes_exactly_k) > 0) {
    for (nm in names(results_obj$genes_exactly_k)) {
      genes <- results_obj$genes_exactly_k[[nm]]
      if (length(genes) > 0) {
        sheet_nm <- sanitize_sheet_name(nm)
        sheets[[sheet_nm]] <- data.frame(gene = genes, stringsAsFactors = FALSE) %>%
          dplyr::left_join(gene_id_map, by = "gene") %>%
          dplyr::relocate(Other_Name, .after = gene)
      }
    }
  }
  
  # --- 4) keep your shared_all convenience sheet if present ---
  if (!is.null(results_obj$genes_all) && length(results_obj$genes_all) > 0) {
    sheets[["shared_all"]] <- data.frame(gene = results_obj$genes_all, stringsAsFactors = FALSE) %>%
      dplyr::left_join(gene_id_map, by = "gene") %>%
      dplyr::relocate(Other_Name, .after = gene)
  }
  
  # --- 5) summaries ---
  if (!is.null(results_obj$summary_patterns)) {
    sheets[["summary_patterns"]] <- results_obj$summary_patterns
  } else if (!is.null(results_obj$summary)) {
    # fallback if you're still carrying the older summary
    sheets[["summary"]] <- results_obj$summary
  }
  
  # Drop empty sheets (safety)
  sheets <- sheets[vapply(sheets, nrow, integer(1)) > 0]
  
  writexl::write_xlsx(sheets, outfile)
}

